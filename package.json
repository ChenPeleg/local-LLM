{
  "name": "local-llm",
  "version": "1.0.0",
  "type": "module",
  "description": "A local LLM project",
  "main": "index.js",
  "scripts": {
    "dev": "cn --config continue-config.yaml",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "echo \"started ",
    "fibonacci": "node src/fibonacci.ts",
    "extract-games": "node scripts/extract-games.ts",
    "ollama:install": "ollama pull qwen2.5-coder:14b",
    "ollama:addpath": "powershell -Command \"[Environment]::SetEnvironmentVariable('Path', [Environment]::GetEnvironmentVariable('Path', 'User') + ';' + $env:LOCALAPPDATA + '\\Programs\\Ollama', 'User')\"",
    "ollama:start": "dotenv -e .env.ollama -- ollama serve",
    "ollama:stop": "taskkill /IM ollama.exe /F"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.1",
    "dotenv-cli": "^11.0.0",
    "opencode-ai": "^1.3.2"
  }
}